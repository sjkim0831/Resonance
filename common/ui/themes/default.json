{
  "id": "default",
  "name": "기본 테마",
  "colors": {
    "primary": "#3B82F6",
    "secondary": "#6366F1",
    "accent": "#8B5CF6",
    "background": "#FFFFFF",
    "surface": "#F9FAFB",
    "text": "#111827",
    "textSecondary": "#6B7280",
    "border": "#E5E7EB",
    "error": "#EF4444",
    "warning": "#F59E0B",
    "success": "#10B981",
    "info": "#3B82F6"
  },
  "fonts": {
    "family": "Inter, -apple-system, BlinkMacSystemFont, sans-serif",
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "xxl": "1.5rem"
    },
    "weight": {
      "normal": 400,
      "medium": 500,
      "bold": 600
    }
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem"
  },
  "borderRadius": {
    "sm": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1)",
    "none": "none"
  },
  "components": {
    "button": {
      "primaryBg": "#3B82F6",
      "primaryColor": "#FFFFFF",
      "secondaryBg": "#FFFFFF",
      "secondaryColor": "#374151",
      "borderRadius": "0.375rem",
      "padding": "0.5rem 1rem",
      "fontSize": "0.875rem"
    },
    "input": {
      "background": "#FFFFFF",
      "border": "#D1D5DB",
      "color": "#111827",
      "focusBorder": "#3B82F6",
      "borderRadius": "0.375rem",
      "padding": "0.5rem 0.75rem"
    },
    "table": {
      "headerBg": "#F9FAFB",
      "headerColor": "#374151",
      "rowBg": "#FFFFFF",
      "rowAltBg": "#F9FAFB",
      "border": "#E5E7EB",
      "hoverBg": "#F3F4F6"
    },
    "card": {
      "background": "#FFFFFF",
      "border": "#E5E7EB",
      "borderRadius": "0.5rem",
      "padding": "1rem",
      "shadow": "0 1px 3px 0 rgb(0 0 0 / 0.1)"
    }
  }
