{
  "id": "corporate",
  "name": "기업 테마",
  "colors": {
    "primary": "#1E40AF",
    "secondary": "#3730A3",
    "accent": "#5B21B6",
    "background": "#F8FAFC",
    "surface": "#FFFFFF",
    "text": "#0F172A",
    "textSecondary": "#475569",
    "border": "#CBD5E1",
    "error": "#DC2626",
    "warning": "#D97706",
    "success": "#059669",
    "info": "#2563EB"
  },
  "fonts": {
    "family": "Pretendard, -apple-system, BlinkMacSystemFont, sans-serif",
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "xxl": "1.5rem"
    },
    "weight": {
      "normal": 400,
      "medium": 500,
      "bold": 700
    }
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem"
  },
  "borderRadius": {
    "sm": "0.125rem",
    "md": "0.25rem",
    "lg": "0.375rem",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "md": "0 2px 4px -1px rgb(0 0 0 / 0.1)",
    "lg": "0 4px 6px -2px rgb(0 0 0 / 0.1)",
    "none": "none"
  },
  "components": {
    "button": {
      "primaryBg": "#1E40AF",
      "primaryColor": "#FFFFFF",
      "secondaryBg": "#FFFFFF",
      "secondaryColor": "#1E40AF",
      "borderRadius": "0.25rem",
      "padding": "0.5rem 1rem",
      "fontSize": "0.875rem"
    },
    "input": {
      "background": "#FFFFFF",
      "border": "#CBD5E1",
      "color": "#0F172A",
      "focusBorder": "#1E40AF",
      "borderRadius": "0.25rem",
      "padding": "0.5rem 0.75rem"
    },
    "table": {
      "headerBg": "#F1F5F9",
      "headerColor": "#0F172A",
      "rowBg": "#FFFFFF",
      "rowAltBg": "#F8FAFC",
      "border": "#E2E8F0",
      "hoverBg": "#F1F5F9"
    },
    "card": {
      "background": "#FFFFFF",
      "border": "#E2E8F0",
      "borderRadius": "0.375rem",
      "padding": "1rem",
      "shadow": "0 1px 2px 0 rgb(0 0 0 / 0.05)"
    }
  }
}
