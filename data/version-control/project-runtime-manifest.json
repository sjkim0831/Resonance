{
  "projects": {
    "P001": {
      "metadata": {
        "projectId": "P001",
        "projectName": "Carbonet Standard Project",
        "owner": "carbonet-core-team",
        "description": "Default standard project for Carbonet platform"
      },
      "installations": {
        "commonCore": "1.1.0",
        "stableGate": "v1",
        "adapter": "1.0.0",
        "adapterContract": "v1"
      },
      "bindings": {
        "database": {
          "bindingMode": "COMMON_DB + PROJECT_DB",
          "commonDb": {
            "url": "jdbc:cubrid:localhost:33000:carbonet_common:::?charset=utf-8",
            "schema": "public"
          },
          "projectDb": {
            "url": "jdbc:cubrid:localhost:33000:carbonet_p001:::?charset=utf-8",
            "schema": "public"
          }
        },
        "theme": {
          "id": "carbonet-default-dark",
          "version": "1.0.0"
        },
        "menu": {
          "profile": "standard-admin-v1",
          "apiPrefix": "/api/v1/p001"
        }
      },
      "runtime": {
        "packagePath": "apps/project-runtime/target/project-runtime.jar",
        "adapterArtifactPath": "var/run/project-runtime/P001/lib/project-adapter.jar",
        "manifestPath": "var/run/project-runtime/P001/config/manifest.json",
        "bootTarget": "var/run/project-runtime/P001/project-runtime.jar",
        "bootCommand": "java -jar var/run/project-runtime/P001/project-runtime.jar --spring.profiles.active=prod --app.project-id=P001 --server.port=18000",
        "runtimeMode": "DEDICATED_PROJECT_RUNTIME",
        "lane": "PROJECT_RUNTIME",
        "sharedRuntimeId": "project-runtime-common",
        "routing": {
          "selectorPath": "/projects/P001",
          "routePrefix": "/r/P001",
          "externalBaseUrl": "https://p001.example.com",
          "domainHost": "p001.example.com",
          "managementPath": "/api/operations/governance/runtime/projects/P001",
          "infoPath": "/api/runtime/project-info"
        },
        "status": "STOPPED",
        "lastHealthCheck": null
      },
      "governance": {
        "compatibilityClass": "IMPLEMENTATION_SAFE",
        "updatedAt": "2026-04-16T11:00:00Z"
      }
    },
