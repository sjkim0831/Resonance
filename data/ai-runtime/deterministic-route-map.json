{
  "schemaVersion": "1.0",
  "canonicalRoot": "/opt/Resonance",
  "purpose": "Keep small/local models from scanning the whole workspace. Always resolve intent to bounded file sets first.",
  "readBudgets": {
    "defaultMaxFiles": 12,
    "defaultMaxBytesPerFile": 60000,
    "wideSearchMaxFiles": 40,
    "implementationMaxFiles": 6,
    "verificationMaxFiles": 12
  },
  "zones": [
    {
      "name": "operations-platform",
      "metaphor": "space-station",
      "roots": [
        "apps/operations-console",
        "modules/resonance-ops",
        "ops",
        "deploy",
        "data/version-control",
        "data/ai-runtime"
      ],
      "owns": [
        "runtime lifecycle",
        "install page",
        "backup",
        "rollback",
        "k8s",
        "ollama control plane",
        "version control"
      ]
    },
    {
      "name": "common-framework",
      "metaphor": "jetpack",
      "roots": [
        "modules/resonance-common",
        "modules/resonance-builder",
        "adapters/resonance-common-adapter",
        "package-sets/common"
      ],
      "owns": [
        "shared jars",
        "authority/scope foundation",
        "screen builder core",
        "theme builder core",
        "standard-framework module updates"
      ]
    },
    {
      "name": "project-carbonet",
      "metaphor": "rocket",
      "roots": [
        "projects/carbonet-adapter",
        "projects/carbonet-runtime",
        "projects/carbonet-config",
        "projects/carbonet-frontend",
        "apps/carbonet-app",
        "package-sets/projects/carbonet-package-set.example.yaml"
      ],
      "owns": [
        "thin project code",
        "project-specific pages",
        "project adapter bindings",
        "project package"
      ]
    },
    {
      "name": "builder-system",
      "metaphor": "launch-factory",
      "roots": [
        "modules/resonance-builder",
        "templates",
        "data/screen-builder",
        "projects/project-template",
        "projects/project-template-adapter"
      ],
      "owns": [
        "screen builder",
        "component builder",
        "theme management",
        "scaffolding",
        "project package generation"
      ]
    }
  ],
  "intentRoutes": [
    {
      "match": [
        "permission",
        "authority",
        "scope",
        "role",
        "account",
        "login",
        "security"
      ],
      "readFirst": [
        "docs/authority-api-review.md",
        "modules/resonance-common/common-auth",
        "modules/resonance-common/carbonet-common-core/src/main/java/egovframework/com/config/security",
        "projects/carbonet-frontend/source/src/features/admin-permissions"
      ],
      "doNotStartWith": [
        "all modules",
        "frontend/node_modules",
        "target"
      ]
    },
    {
      "match": [
        "screen builder",
        "component builder",
        "theme",
        "scaffold",
        "template"
      ],
      "readFirst": [
        "data/theme-registry/theme-registry.json",
        "ops/scripts/verify-theme-registry.sh",
        "docs/resonance-authority-builder-theme-review.md",
        "docs/resonance-builder-evolution-plan.md",
        "templates/screenbuilder-project-bootstrap/manifests/theme-install-manifest.json",
        "modules/resonance-builder",
        "data/screen-builder",
        "projects/project-template"
      ],
      "doNotStartWith": [
        "apps/carbonet-app/target",
        "projects/carbonet-frontend/source/node_modules"
      ]
    },
    {
      "match": [
        "k8s",
        "docker",
        "deploy",
        "restart",
        "rollback",
        "backup",
        "migration",
        "transfer"
      ],
      "readFirst": [
        "docs/resonance-k8s-3b-agent-operations.md",
        "ops/project-paths.sh",
        "ops/scripts",
        "deploy/k8s",
        "data/version-control"
      ],
      "doNotStartWith": [
        "var/logs",
        "data/*/*.log"
      ]
    },
    {
      "match": [
        "build version",
        "version metadata",
        "release manifest",
        "package registry",
        "compatibility matrix",
        "runtime status",
        "image tag"
      ],
      "readFirst": [
        "data/version-control/project-runtime-manifest.json",
        "data/version-control/package-registry.json",
        "data/version-control/compatibility-matrix.json",
        "data/version-control/k8s-runtime-status-20260427.json",
        "manifests/resonance-k8s-release-manifest.example.yaml",
        "ops/scripts/verify-build-version-metadata.sh",
        "docs/agent/resonance-hermes-rag-workboard-20260427.md"
      ],
      "doNotStartWith": [
        "whole repository scan",
        "apps/*/target",
        "projects/carbonet-frontend/source/node_modules"
      ]
    },
    {
      "match": [
        "ollama",
        "3b",
        "local model",
        "agent",
        "ai runtime"
      ],
      "readFirst": [
        "data/ai-runtime/deterministic-agent-policy.json",
        "ops/scripts/verify-deterministic-agent-policy.sh",
        "data/ai-runtime/ollama-control-plane.json",
        "docs/agent/deterministic-3b-agent-playbook.md",
        "modules/resonance-ops/ollama-control-plane",
        "skills/resonance-workflow/SKILL.md"
      ],
      "doNotStartWith": [
        "whole repository scan"
      ]
    },
    {
      "match": [
        "hermes",
        "rag",
        "context pack",
        "agent orchestration",
        "bounded context"
      ],
      "readFirst": [
        "data/ai-runtime/hermes-rag-context-pack.json",
        "docs/agent/hermes-rag-agent-playbook.md",
        "ops/scripts/run-hermes-rag-smoke.sh",
        "ops/scripts/render-hermes-task-packet.sh",
        "ops/scripts/run-hermes-worker-loop.sh",
        "data/ai-runtime/hermes-patch-packet.schema.json",
        "ops/scripts/render-hermes-patch-packet.sh",
        "ops/scripts/validate-hermes-patch-packet.sh",
        "data/ai-runtime/hermes-implementation-packet.schema.json",
        "ops/scripts/render-hermes-implementation-packet.sh",
        "ops/scripts/validate-hermes-implementation-packet.sh",
        "data/ai-runtime/agent-stage-model-matrix.json",
        "docs/agent/deterministic-3b-agent-playbook.md",
        "skills/resonance-workflow/SKILL.md"
      ],
      "doNotStartWith": [
        "whole repository scan",
        "projects/carbonet-frontend/source/node_modules",
        "apps/carbonet-app/target",
        "var"
      ]
    },
    {
      "match": [
        "project split",
        "project boundary",
        "boundary contract",
        "common jar",
        "adapter",
        "carbonet",
        "resonance"
      ],
      "readFirst": [
        "data/project-boundary/resonance-carbonet-boundary-contract.json",
        "ops/scripts/verify-project-boundary.sh",
        "docs/resonance-carbonet-boundary-matrix.md",
        "docs/resonance-common-jar-governance.md",
        "projects/pom.xml",
        "modules/pom.xml",
        "package-sets"
      ],
      "doNotStartWith": [
        "legacy candidates until classification is requested"
      ]
    }
  ],
  "gates": [
    "Never edit more than 6 files in one implementation pass without a refreshed plan.",
    "Before implementation, output selected files and reason for each.",
    "After implementation, run the smallest build/smoke gate that covers touched files.",
    "If target files cannot be resolved deterministically, stop with NEEDS_ROUTE_MAP instead of broad scanning."
  ]
}
