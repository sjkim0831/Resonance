      "patternId": "security.authority-scope-gate",
      "title": "Authority Scope Gate Pattern",
      "layer": "common-framework",
      "languages": ["java", "sql", "xml"],
      "purpose": "Add or verify role, scope, feature, action, and resource checks through the existing Resonance authority foundation.",
      "inputs": ["featureId", "roleId", "scopeRule", "actionId", "resourceId"],
