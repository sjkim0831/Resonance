      "allowedOutputs": ["gate API method", "scope check", "authority mapper query", "safe DTO field", "verification note"],
      "forbidden": ["second permission engine", "ROLE_ADMIN execute grant", "unscoped admin endpoint", "master-only operation exposed below ROLE_SYSTEM_MASTER"],
      "verification": ["authority/scope review", "targeted Maven compile", "COMTNAUTHORFUNCTIONRELATE data check when DB access is needed"],
      "risk": "master-only",
      "modelRole": "validator",
      "notes": "Security is always validator-governed; local models may summarize or draft bounded checks only."
    },
    {
