{
  "schemaVersion": "1.0",
  "cards": [
    {
      "schemaVersion": "1.0",
      "patternId": "k8s.recovery.crashloopbackoff",
      "title": "Kubernetes CrashLoopBackOff Recovery Pattern",
      "layer": "operations-platform",
      "languages": ["yaml", "shell", "json"],
      "purpose": "Classify CrashLoopBackOff causes and select a bounded recovery path using logs, events, probes, config, secrets, image metadata, and rollback gates.",
      "inputs": ["namespace", "workload", "pod", "previousLogs", "events", "lastRelease", "imageTag"],
      "readFirst": ["deploy/k8s/projects/carbonet/carbonet-runtime.deployment.yaml", "ops/scripts/restart-local-carbonet-k8s.sh", "ops/scripts/rollback-project-release.sh", "data/version-control/project-runtime-manifest.json"],
      "allowedOutputs": ["cause classification", "selected recovery script", "rollback recommendation", "probe/config fix draft", "verification summary"],
      "forbidden": ["blind restart loop", "raw kubectl patch without manifest validation", "rollback without known target", "DB mutation as first response"],
      "verification": ["pod restarts decrease", "readiness passes", "runtime freshness verification", "event log no longer reports same root cause"],
      "risk": "master-only",
      "modelRole": "validator",
      "notes": "AI classifies; deterministic scripts restart or rollback."
    },
    {
      "schemaVersion": "1.0",
      "patternId": "k8s.recovery.oomkilled-pressure",
      "title": "Kubernetes OOMKilled And Pressure Recovery Pattern",
      "layer": "operations-platform",
      "languages": ["yaml", "shell"],
      "purpose": "Recover from OOMKilled, memory pressure, CPU pressure, or disk pressure using resource diagnosis, limits review, scale/rollback options, and pressure checks.",
      "inputs": ["namespace", "workload", "container", "oomEvents", "resourceRequests", "resourceLimits", "nodePressure"],
      "readFirst": ["ops/scripts/check-runtime-pressure.sh", "deploy/k8s/projects/carbonet/carbonet-runtime.deployment.yaml", "deploy/k8s/projects/carbonet/cubrid-carbonet.statefulset.yaml"],
      "allowedOutputs": ["pressure classification", "resource request/limit draft", "restart/rollback recommendation", "scale recommendation", "cleanup recommendation"],
      "forbidden": ["infinite restart on OOM", "resource increase without node capacity check", "DB pod kill before backup/restore assessment", "cluster-wide change without approval"],
      "verification": ["check-runtime-pressure.sh", "pod memory stabilizes", "readiness passes", "restart count stops rising"],
      "risk": "master-only",
      "modelRole": "validator",
      "notes": "Prefer cause removal over restart."
    },
    {
      "schemaVersion": "1.0",
      "patternId": "k8s.recovery.readiness-liveness-failure",
      "title": "Kubernetes Probe Failure Recovery Pattern",
      "layer": "operations-platform",
      "languages": ["yaml", "shell"],
      "purpose": "Handle readiness, liveness, and startup probe failures by distinguishing slow startup, dependency outage, wrong endpoint, bad config, and actual application failure.",
      "inputs": ["namespace", "workload", "probeType", "probePath", "events", "healthResponse", "startupTime"],
      "readFirst": ["deploy/k8s/projects/carbonet/carbonet-runtime.deployment.yaml", "deploy/k8s/projects/carbonet/cubrid-carbonet.statefulset.yaml", "ops/scripts/restart-local-carbonet-k8s.sh"],
      "allowedOutputs": ["probe failure classification", "probe tuning draft", "dependency recovery recommendation", "runtime restart recommendation", "verification summary"],
      "forbidden": ["disable probes to hide failure", "liveness too aggressive for DB startup", "restart before dependency check", "probe endpoint change without app contract review"],
      "verification": ["startup probe succeeds", "readiness stays true", "liveness restart count stable", "health endpoint returns expected state"],
      "risk": "high",
      "modelRole": "validator",
      "notes": "Existing manifests already use probes; AI should diagnose before changing thresholds."
    },
    {
      "schemaVersion": "1.0",
      "patternId": "k8s.recovery.imagepull-config-secret",
      "title": "Kubernetes ImagePull Config Secret Recovery Pattern",
      "layer": "operations-platform",
      "languages": ["yaml", "shell"],
      "purpose": "Recover from ImagePullBackOff, ErrImagePull, ConfigMap missing, Secret missing, or invalid environment binding.",
      "inputs": ["namespace", "workload", "imageTag", "imagePullPolicy", "missingConfig", "missingSecret", "events"],
      "readFirst": ["deploy/k8s/projects/carbonet/carbonet-runtime.deployment.yaml", "deploy/k8s/base/operations-console.deployment.yaml", "ops/scripts/build-kind-runtime-image.sh", "ops/scripts/verify-build-version-metadata.sh"],
      "allowedOutputs": ["missing artifact classification", "image build/load recommendation", "config/secret manifest validation result", "safe redeploy recommendation"],
      "forbidden": ["commit real secret values", "switch to latest tag as fix", "manual secret creation without manifest path", "image rebuild without metadata"],
      "verification": ["image available", "config/secret exists", "pod scheduled", "runtime freshness verification"],
      "risk": "master-only",
      "modelRole": "validator",
      "notes": "Secret values stay outside model-visible pattern output."
    },
    {
      "schemaVersion": "1.0",
      "patternId": "k8s.recovery.db-statefulset-dependency",
      "title": "Kubernetes DB StatefulSet Dependency Recovery Pattern",
      "layer": "operations-platform",
      "languages": ["yaml", "shell", "sql"],
      "purpose": "Recover application or DB availability when the CUBRID StatefulSet, PVC, broker port, or DB readiness dependency is degraded.",
      "inputs": ["namespace", "statefulset", "pvcStatus", "brokerPort", "dbReadiness", "appDependencyError"],
      "readFirst": ["deploy/k8s/projects/carbonet/cubrid-carbonet.statefulset.yaml", "ops/scripts/apply-project-db-migration.sh", "ops/scripts/restart-local-carbonet-k8s.sh"],
      "allowedOutputs": ["DB dependency classification", "PVC/broker readiness summary", "app wait recommendation", "backup/restore escalation recommendation"],
      "forbidden": ["delete PVC as recovery", "DB migration during unstable DB", "force app restart loop before DB readiness", "unrecorded DB repair"],
      "verification": ["StatefulSet ready", "broker tcp probe passes", "app readiness passes", "DB migration history intact when checked"],
      "risk": "master-only",
      "modelRole": "validator",
      "notes": "DB recovery is backup/restore governed and must be conservative."
    },
    {
      "schemaVersion": "1.0",
      "patternId": "k8s.recovery.node-eviction-scheduling",
      "title": "Kubernetes Node Eviction Scheduling Recovery Pattern",
      "layer": "operations-platform",
      "languages": ["yaml", "shell"],
      "purpose": "Handle Pending pods, evictions, node pressure, affinity/resource scheduling failures, and unavailable nodes.",
      "inputs": ["namespace", "workload", "podStatus", "nodeStatus", "schedulerEvents", "resourceRequests"],
      "readFirst": ["deploy/k8s/base/namespaces.yaml", "deploy/k8s/projects/carbonet/carbonet-runtime.deployment.yaml", "ops/scripts/check-runtime-pressure.sh", "ops/scripts/prepare-docker-desktop-k8s-gate.sh"],
      "allowedOutputs": ["scheduling failure classification", "resource adjustment draft", "node pressure summary", "reschedule/restart recommendation"],
      "forbidden": ["lower resource requests below safe runtime minimum", "evict DB pod without backup gate", "cluster-wide drain by model", "blind delete pod loop"],
      "verification": ["pod scheduled", "node pressure healthy", "readiness passes", "restart count stable"],
      "risk": "high",
      "modelRole": "validator",
      "notes": "Use Kubernetes scheduler evidence first."
    },
    {
      "schemaVersion": "1.0",
      "patternId": "k8s.recovery.rollout-stuck",
      "title": "Kubernetes Rollout Stuck Recovery Pattern",
      "layer": "operations-platform",
      "languages": ["yaml", "shell", "json"],
      "purpose": "Recover stuck deployments, unavailable replicas, failed rollout, or stale ReplicaSets by comparing release metadata and rollout status.",
      "inputs": ["namespace", "deployment", "desiredReplicas", "availableReplicas", "rolloutStatus", "lastGoodRevision"],
      "readFirst": ["ops/scripts/deploy-project-release.sh", "ops/scripts/rollback-project-release.sh", "ops/scripts/codex-verify-18000-freshness.sh", "data/version-control/project-runtime-manifest.json"],
      "allowedOutputs": ["rollout failure classification", "pause/rollback recommendation", "freshness mismatch summary", "verification summary"],
      "forbidden": ["scale to zero as recovery without approval", "manual ReplicaSet deletion as first response", "continue rollout after failed health", "rollback without known good revision"],
      "verification": ["rollout status complete", "available replicas match desired", "runtime freshness passes", "health smoke passes"],
      "risk": "master-only",
      "modelRole": "validator",
      "notes": "Rollback is favored over repeated restarts when the new revision is bad."
    }
  ]
}
