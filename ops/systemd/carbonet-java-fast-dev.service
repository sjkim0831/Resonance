[Unit]
Description=Carbonet Java fast development runtime
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sjkim
WorkingDirectory=/opt/Resonance
Environment=JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
Environment=JAVA_FAST_DEV_PORT=18000
EnvironmentFile=/opt/resonance-data/config/java-fast-dev-18000.env
ExecStart=/bin/bash /opt/Resonance/ops/scripts/start-java-fast-dev.sh
Restart=always
RestartSec=3
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
