# Tracked non-secret defaults shared by the :18001 standby runtime profiles.
#
# Select a profile with CARBONET_RUNTIME_ENV=local or remote-221. Secrets stay
# in ops/config/carbonet-18001.env, ops/config/carbonet-18001.<profile>.env, or
# the process environment.

CARBONET_MENU_EMISSION_ECOINVENT_CODE=A0020113
CARBONET_MENU_EMISSION_ECOINVENT_NAME_KO="ecoinvent 배출계수 관리"
CARBONET_MENU_EMISSION_ECOINVENT_NAME_EN="ecoinvent Emission Factors"
CARBONET_MENU_EMISSION_ECOINVENT_URL=/admin/emission/ecoinvent
CARBONET_MENU_EMISSION_ECOINVENT_ICON=settings_input_composite
CARBONET_ECOINVENT_SEARCH_URL_TEMPLATE="https://api.ecoinvent.org/v0/datasets?query=__QUERY__&from=0&limit=100&version=latest&system_model=cutoff"
