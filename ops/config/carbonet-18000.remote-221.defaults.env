# 221 web server :18000 runtime defaults.
#
# This profile is for a low-memory server where Carbonet runs as a plain JAR
# behind nginx. TLS terminates at nginx, so the runtime itself stays HTTP.

CUBRID_HOST=34.82.141.193
CUBRID_PORT=33000
CUBRID_DB=carbonet
CUBRID_USER=dba

SERVER_SSL_ENABLED=false

CARBONET_RUNTIME_SCHEME=http
CARBONET_RUNTIME_HOST=127.0.0.1
CARBONET_CURL_INSECURE=false
CARBONET_HEALTH_CHECK_URL=http://127.0.0.1:18000/actuator/health

CARBONET_REACT_APP_FS_OVERRIDE_ENABLED=false
