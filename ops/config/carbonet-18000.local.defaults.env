# Local PC :18000 runtime defaults.
#
# Local browser development uses plain HTTP. TLS terminates at an optional
# reverse proxy/tunnel, never on the application port itself.

CUBRID_HOST=127.0.0.1
CUBRID_PORT=33000
CUBRID_DB=carbonet
CUBRID_USER=dba

SERVER_SSL_ENABLED=false

CARBONET_RUNTIME_SCHEME=http
CARBONET_RUNTIME_HOST=127.0.0.1
CARBONET_CURL_INSECURE=false
CARBONET_HEALTH_CHECK_URL=http://127.0.0.1:18000/actuator/health

# The local build writes here atomically; using the build output prevents a
# stale bundle embedded in an older runtime jar from shadowing current UI work.
CARBONET_REACT_APP_FS_OVERRIDE_ENABLED=true
CARBONET_REACT_APP_FS_OVERRIDE_PATH=/home/sjkim/Resonance-5fcc8971ae/projects/carbonet-frontend/src/main/resources/static/react-app
