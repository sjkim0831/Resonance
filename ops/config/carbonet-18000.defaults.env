# Tracked non-secret defaults for the local/221 :18000 runtime.
#
# Keep secrets in the ignored ops/config/carbonet-18000.env file or pass them
# from the execution environment. This file exists so a fresh clone keeps the
# TLS runtime shape even when local secret env files are not committed.

SERVER_SSL_ENABLED=true
SERVER_SSL_KEY_STORE=/opt/Resonance/ops/config/certs/carbonet-localhost.p12
SERVER_SSL_KEY_STORE_PASSWORD=changeit
SERVER_SSL_KEY_STORE_TYPE=PKCS12
SERVER_SSL_KEY_ALIAS=carbonet-local

CARBONET_RUNTIME_SCHEME=https
CARBONET_RUNTIME_HOST=127.0.0.1
CARBONET_CURL_INSECURE=true
CARBONET_HEALTH_CHECK_URL=https://127.0.0.1:18000/actuator/health

CARBONET_REACT_APP_FS_OVERRIDE_ENABLED=true
CARBONET_REACT_APP_FS_OVERRIDE_PATH=/opt/Resonance/src/main/resources/static/react-app
