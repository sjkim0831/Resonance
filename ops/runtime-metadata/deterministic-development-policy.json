{
  "policyId": "resonance-deterministic-first-development",
  "version": "1.0.0",
  "defaultExecutionOrder": [
    "EXACT_EXISTING_IMPLEMENTATION",
    "REGISTERED_COMMON_ASSET",
    "DETERMINISTIC_GENERATOR",
    "LOCAL_SELECTOR",
    "AI_ESCALATION"
  ],
  "deterministicJobTypes": [
    "REFERENCE_ANALYSIS",
    "DESIGN",
    "DESIGN_PREFLIGHT",
    "FULL_STACK_GENERATION",
    "DEPLOYMENT",
    "API",
    "API_QUALITY",
    "BACKEND",
    "BACKEND_QUALITY",
    "NOTIFICATION",
    "DATABASE",
    "DATABASE_QUALITY",
    "SEARCH",
    "PERFORMANCE",
    "TEST",
    "ACTOR_TEST",
    "INTEGRATION"
  ],
  "evidenceRequired": true,
  "allowUnverifiedCompletion": false,
  "aiEscalation": {
    "allowedOnlyWhenDeterministicResultIs": "NOT_HANDLED",
    "recordReason": true,
    "maximumAutomaticAttempts": 1
  }
}
