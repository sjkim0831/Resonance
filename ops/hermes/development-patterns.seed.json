      "checks": [
        [
          "BUILD",
          "cd frontend && npm run build",
          "exit_code=0"
        ],
        [
          "BUILD",
          "mvn -q -DskipTests package",
          "exit_code=0"
        ],
        [
          "ROUTE",
          "curl -sI http://127.0.0.1/ | head",
          "HTTP 2xx/3xx"
        ]
      ],
      "artifacts": [
        [
          "frontend",
