  "patterns": [
    {
      "patternId": "BUILD_RESTART_18000",
      "categoryCode": "DEPLOY",
      "patternName": "Local build restart and freshness verification",
      "riskLevel": "MEDIUM",
      "skillName": "carbonet-fast-bootstrap-ops",
      "defaultActionId": "build-restart-18000",
      "triggerKeywords": [
        "18000",
        "구동",
        "재시작",
        "빌드",
        "로컬",
        "freshness",
        "runtime"
      ],
      "routeHints": [
        ":18000"
      ],
      "moduleHints": [
        "frontend",
        "apps/carbonet-app",
        "ops/scripts"
      ],
      "teamRules": {
        "requiredTeams": [
          "build-release",
          "ops-control"
        ],
        "gateTeams": [
          "build-release"
        ],
        "supportTeams": [
          "web-pod-ops",
          "qa-audit"
        ],
        "selectionReason": "로컬 런타임 freshness와 재시작 증거가 핵심이다."
      },
      "steps": [
        [
          "REQUEST_CAPTURE",
          "요청 원문과 대상 런타임을 기록한다.",
          "raw_request, trace_id"
        ],
        [
          "SIMILAR_WORK_RETRIEVAL",
          "유사 작업, 참조 페이지, 실패/수정 이력, 추가 검수 항목을 조회하고 현재 작업 체크리스트에 반영한다.",
          "reference_tasks, reference_pages, lessons_applied, additional_checks"
        ],
        [
          "PRECHECK",
          "git 상태와 기존 18000 프로세스/포트 상태를 확인한다.",
          "git_status, pid_or_port_status"
        ],
        [
          "WORK_PACKET_READY",
          "선택 패턴, 참조 작업, 참조 파일, 적용 교훈, 추가 검수, 기대 증거를 압축 가능한 작업 봉투로 저장한다.",
          "work_packet_id, source_artifacts_to_open, expected_evidence"
        ],
        [
          "IMPLEMENT",
          "필요한 소스 변경 또는 설정 변경을 적용한다.",
          "changed_files, patch_summary"
        ],
        [
          "VERIFY",
          "ops/scripts/build-restart-18000.sh 후 freshness verifier를 실행한다.",
          "build_log, runtime_jar_match, health_or_route_probe"
        ],
        [
          "REFLECT",
          "재사용 가능한 실패/성공 패턴을 Hermes memory에 남긴다.",
          "result_summary, reusable_pattern"
        ]
      ],
      "checks": [
        [
          "BUILD",
          "bash ops/scripts/build-restart-18000.sh",
          "exit_code=0"
        ],
        [
          "RUNTIME",
          "VERIFY_WAIT_SECONDS=20 bash ops/scripts/codex-verify-18000-freshness.sh",
          "pid_alive, port_listening, jar_match"
        ]
      ],
      "artifacts": [
        [
          "frontend",
          "frontend/src/**",
          "FRONTEND"
        ],
        [
          "backend",
          "apps/carbonet-app/**",
          "BACKEND"
        ],
        [
          "script",
          "ops/scripts/**",
          "SCRIPT"
        ]
      ]
    },
