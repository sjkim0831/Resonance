      "judge": "main-qwen36-40b-hermes-framework-exl3"
    },
    "autoHermesDiscovery": true,
    "preferLiveOnly": true,
    "warmPoolPolicy": {
      "alwaysKeep": [
        "main-qwen36-40b-hermes-framework-exl3",
        "sub-qwen7-coder-cpu",
        "translation-gemma4-e4b-gpu",
        "micro-router-qwen05-cpu",
        "utility-qwen15-cpu"
      ],
      "speedFirst": true,
      "gpu7bPolicy": "candidate-only: start a GPU 7B only after measuring that Qwen40 throughput and latency do not regress",
      "idleStopMinutes": {
        "sub-qwen14-coder-gpu": 0,
        "utility-qwen3b-cpu": 30,
        "main-qwen36-40b-gpu": 0,
        "main-qwen36-40b-hermes-framework-exl3": 0,
        "translation-qwen25-3b-exl2-gpu": 1
      },
      "oomFallbackOrder": [
        "keep main-qwen36-40b-hermes-framework-exl3 as the active main judge",
        "stop optional GPU translation/sub models before stopping the active main judge",
        "fall back to main-qwen36-40b-gpu only by explicit operator approval"
      ]
    },
    "hermesSupervisorPolicy": {
      "supervisorRole": "sub",
      "supervisorProfile": "sub-qwen7-coder-cpu",
      "checkpointCadence": "task-stage, command-result, or 100-300 generated-token checkpoint; never per-token DB writes",
      "detect": [
        "empty task extraction",
        "same command repeated",
        "same error repeated",
        "terminal preparing loop",
        "no output timeout",
        "model download loop",
        "context compression stall",
        "success without evidence"
      ],
      "feedbackSink": "/opt/Resonance/var/ai-runtime/hermes-watchdog/hermes-watchdog-events.jsonl",
      "dbPolicy": "store task/checkpoint/problem/fix summaries after checkpoints; do not store secrets or raw credentials"
    },
    "exl2Policy": {
      "qwen40Requested": true,
      "qwen40Exl2Status": "unsupported-by-exllamav2-for-qwen3_5-linear-attention",
      "activeServing": "tabbyapi-exllamav3-exl3-4.0bpw-with-qlora",
      "activeProfile": "main-qwen36-40b-hermes-framework-exl3",
      "reason": "Qwen3.6 40B HF config exposes Qwen3_5ForConditionalGeneration and linear_attn modules; ExLlamaV2 expects older module names."
    }
  },
