SECURITY_CODEX_ENABLED=true
SECURITY_CODEX_API_KEY=CHANGE_THIS_TO_A_LOCAL_SECRET

SECURITY_CODEX_RUNNER_ENABLED=true
SECURITY_CODEX_RUNNER_REPO_ROOT=/opt/Resonance
SECURITY_CODEX_RUNNER_WORKSPACE_ROOT=/tmp/carbonet-sr-codex-runner
SECURITY_CODEX_RUNNER_HISTORY_FILE=/tmp/carbonet-sr-codex-runner-history.jsonl
SECURITY_CODEX_RUNNER_ALLOWED_PATH_PREFIXES=src/main/java,src/main/resources,frontend/src,docs/ai,ops/scripts

SECURITY_CODEX_RUNNER_PLAN_COMMAND=ops/scripts/codex-plan.sh {promptFile} {worktree} {resultFile}
SECURITY_CODEX_RUNNER_BUILD_COMMAND=ops/scripts/codex-build.sh {promptFile} {worktree} {resultFile}

SECURITY_CODEX_RUNNER_BACKEND_VERIFY_COMMAND=mvn -q -DskipTests package
SECURITY_CODEX_RUNNER_FRONTEND_VERIFY_COMMAND=npm run build
SECURITY_CODEX_RUNNER_FRONTEND_VERIFY_WORKDIR=frontend
