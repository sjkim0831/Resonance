# Copy this file to:
#   ops/config/deploy-automation.env
# That file is git-ignored and can hold local automation secrets.

# Git push / remote clone auth
# GITHUB_TOKEN=ghp_xxx

# 221 deploy target
# MAIN_REMOTE_PASSWORD=replace-me
# MAIN_REMOTE_PORT=22
# MAIN_REMOTE_ROOT=/opt/Resonance
# CARBONET_RUNTIME_ENV=remote-221

# Remote DB JDBC auth if different from local
# REMOTE_DB_USER=dba
# REMOTE_DB_PASSWORD=
# REMOTE_DB_NAME=carbonet
# REMOTE_DB_TUNNEL_PORT=13300

# ecoinvent OAuth credentials
# CARBONET_ECOINVENT_CLIENT_ID=replace-me
# CARBONET_ECOINVENT_CLIENT_SECRET=replace-me

# Local DB override if needed
# LOCAL_DB_HOST=127.0.0.1
# LOCAL_DB_PORT=33000
# LOCAL_DB_NAME=carbonet
# LOCAL_DB_USER=dba
# LOCAL_DB_PASSWORD=
