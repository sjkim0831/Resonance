{
  "name": "carbonet-react-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/fix-playwright-responses-output.mjs",
    "generate:system-component-catalog": "node scripts/generate-system-component-catalog.mjs",
    "generate:framework-contract-metadata": "node scripts/generate-framework-contract-metadata.mjs",
    "generate:verification-center-inventory": "node scripts/generate-verification-center-inventory.mjs",
    "generate:screens": "node scripts/generate-screen-blueprints.mjs",
    "predev": "NODE_OPTIONS=\"--max-old-space-size=${CARBONET_NODE_HEAP_MB:-8192} ${NODE_OPTIONS:-}\" npm run generate:system-component-catalog && NODE_OPTIONS=\"--max-old-space-size=${CARBONET_NODE_HEAP_MB:-8192} ${NODE_OPTIONS:-}\" npm run generate:framework-contract-metadata && NODE_OPTIONS=\"--max-old-space-size=${CARBONET_NODE_HEAP_MB:-8192} ${NODE_OPTIONS:-}\" npm run generate:verification-center-inventory && NODE_OPTIONS=\"--max-old-space-size=${CARBONET_NODE_HEAP_MB:-8192} ${NODE_OPTIONS:-}\" npm run generate:page-completeness-inventory",
    "dev": "NODE_OPTIONS=\"--max-old-space-size=${CARBONET_NODE_HEAP_MB:-8192} ${NODE_OPTIONS:-}\" vite",
    "prebuild": "node scripts/run-frontend-pipeline.mjs",
    "build": "node scripts/run-frontend-pipeline.mjs --build",
    "preview": "vite preview",
    "audit:component-standardization": "node scripts/component-standardization-audit.mjs",
    "audit:framework-contract-metadata": "node scripts/check-framework-contract-metadata.mjs",
    "audit:generated-output": "npm run audit:framework-contract-metadata && node scripts/check-generated-output-governance.mjs",
    "audit:ui-governance": "node scripts/check-ui-governance.mjs",
    "audit:customer-journey": "node scripts/check-customer-journey-governance.mjs",
    "audit:route-registry": "node scripts/check-route-registry-uniqueness.mjs",
    "lane:05:loop": "bash scripts/run-resonance-lane-05-loop.sh",
    "lane:06:loop": "bash scripts/run-resonance-lane-06-loop.sh",
    "lane:09:loop": "bash scripts/run-resonance-lane-09-loop.sh",
    "test:e2e": "playwright test",
    "test:e2e:member-list": "playwright test e2e/member-list.spec.ts",
    "generate:page-completeness-inventory": "node scripts/generate-page-completeness-inventory.mjs"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "1.0.0",
    "@tesseract.js-data/kor": "1.0.0",
    "html2pdf.js": "^0.14.0",
    "jsqr": "^1.4.0",
    "pdfjs-dist": "^4.10.38",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^5.4.10"
  }
}
