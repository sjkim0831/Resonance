    {
      "name": "계측기·교정·측정불확도 관리 권한분리 위반",
      "type": "AUTHORITY",
      "steps": [
        "권한 없는 승인",
        "서버 검증"
      ],
      "status": "APPROVED",
      "caseCode": "METER_CALIBRATION_MANAGEMENT_AUTHORITY",
      "assertions": [
        "403 거부",
        "감사로그 기록",
        "상태 불변"
      ],
      "preconditions": "수행자가 승인 명령 시도"
